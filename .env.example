# ==============================================================
# Streamlit Starter — Environment Variables Template
# ==============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git!
# ==============================================================

# --------------------------------------------------------------
# App Settings
# --------------------------------------------------------------
APP_ENV=development          # development | production
APP_TITLE="My Dashboard"
USE_MOCK_AUTH=true           # Set to false in production

# --------------------------------------------------------------
# Azure AD Authentication (OAuth2 / MSAL)
# Required when USE_MOCK_AUTH=false
# --------------------------------------------------------------
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_REDIRECT_URI=http://localhost:8501
# Scope: space-separated list of permissions
AZURE_SCOPE="User.Read openid profile email"

# --------------------------------------------------------------
# Azure Blob Storage Connector
# --------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
# Or use Connection String instead:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_BLOB_CONTAINER_NAME=your-container-name

# --------------------------------------------------------------
# SharePoint Connector (via Microsoft Graph API)
# Uses the same Azure AD App Registration as Auth above
# --------------------------------------------------------------
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/YourSite
SHAREPOINT_DRIVE_ID=your-drive-id
# Or use Site-Relative path: /sites/YourSite/Shared Documents/
